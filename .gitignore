# Generated by drupal/core-composer-scaffold into /web/ and project root.
# See: https://www.drupal.org/docs/develop/using-composer
# =============================================================================
/.editorconfig
/.gitattributes
/web/**/.gitignore
/web/.csslintrc
/web/.editorconfig
/web/.eslintignore
/web/.eslintrc.json
/web/.gitattributes
/web/.htaccess
/web/.ht.router.php
/web/autoload.php
/web/composer.json
/web/composer.lock
/web/example.gitignore
/web/index.php
/web/INSTALL.txt
/web/LICENSE.txt
/web/README.txt
/web/robots.txt
/web/update.php
/web/web.config
