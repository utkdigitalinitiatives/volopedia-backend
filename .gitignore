/web/profiles/README.txt
/web/sites/README.txt
/web/themes/README.txt
/web/sites/development.services.yml
/web/sites/example.settings.local.php
/web/sites/example.sites.php

# =============================================================================
# SENSITIVE SITE CONFIGURATION
# May contain database credentials, API keys, or environment-specific values
# =============================================================================
/web/sites/*/settings*.php
/web/sites/*/services*.yml
!/web/sites/*/services.yml

# =============================================================================
# USER-GENERATED & UPLOADED CONTENT
# =============================================================================
/web/sites/*/files
/web/sites/*/files-public
/web/sites/*/files-private
/web/sites/*/public
/web/sites/*/private

# =============================================================================
# TEMPORARY & CACHED FILES
# =============================================================================
/web/sites/*/translations
/web/sites/*/tmp
/web/sites/*/cache
/web/sites/simpletest

# =============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================
# DDEV per-project config (contains local hostnames and ports)
.ddev/config.yaml

# Editor / IDE settings
/.vscode

# macOS filesystem metadata
.DS_Store

# Local Composer/tool binaries (optional convenience installs)
/composer.phar
/composer
/robo.phar
/robo
/drush.phar
/drush
/drupal.phar
/drupal